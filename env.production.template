# ===========================================
# PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# ===========================================
# Copy this file to .env.production and fill in your actual values
# DO NOT commit actual production values to git!

# ===========================================
# CRITICAL - MUST BE SET
# ===========================================

# Database Configuration
DB_HOST=your_production_db_host
DB_PORT=3306
DB_USERNAME=your_production_db_username
DB_PASSWORD=your_production_db_password
DB_DATABASE=your_production_db_name

# Redis Configuration
REDIS_HOST=your_production_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_production_redis_password

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_for_production
JWT_EXPIRES_IN=7d

# Session Configuration (CRITICAL - CHANGE THIS!)
SESSION_SECRET=your_super_secure_session_secret_for_production

# External APIs (CRITICAL - MUST BE SET)
TWEETSCOUT_API_KEY=your_tweetscout_api_key
TWEETSCOUT_API_URL=https://api.tweetscout.io/v2
TWITTER_SCORE_API_KEY=your_twitter_score_api_key
TWITTER_SCORE_API_URL=https://twitterscore.io/api/v1
TWITTER_ACCOUNT_ID=your_twitter_account_id
TWITTER_ACCOUNT_NAME=y_allery

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_firebase_private_key_here\n-----END PRIVATE KEY-----\n"

# SendGrid Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=your_sendgrid_from_email

# Web App URL (Partner referrals)
WEB_APP_URL=https://yallery.web.app

# ===========================================
# APP CONFIGURATION
# ===========================================

NODE_ENV=production
PORT=8000
FRONTEND_URL=https://your-production-frontend-url.com
API_URL=https://your-production-api-url.com

# ===========================================
# EXISTING VARIABLES (KEEP THESE)
# ===========================================

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Apple OAuth
APPLE_CLIENT_ID=app.yallery
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_apple_private_key_here\n-----END PRIVATE KEY-----"

# Twitter OAuth
TWITTER_CONSUMER_KEY=your_twitter_consumer_key
TWITTER_CONSUMER_SECRET=your_twitter_consumer_secret
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Stripe
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# FAL (AI Service)
FAL_KEY=your_fal_key

# Branch (Analytics)
BRANCH_KEY=your_branch_key

# Gmail
GMAIL_USERNAME=your_gmail_username
GMAIL_PASSWORD=your_gmail_password

# Encryption
ENCRYPTION_KEY=your_encryption_key
ENCRYPTION_IV=your_encryption_iv

# YEPS Configuration
LIKE_SPEND_YEPS=2
LIKE_EARN_YEPS=1
SHARING_REWARD_YEPS=5
IMAGE_GENERATE_SPEND_YEPS=5
YEPS_PER_REGISTRATION=500
DAILY_REWARD_YEPS=100
SHARE_YEPS=5

# X-Router AI Configuration (x402 Payment)
X_ROUTER_API_URL=https://api.x-router.ai/v1/images/generate
X_ROUTER_PRIVATE_KEY=0x... # Ethereum private key for x402 wallet (Base Network)
X_ROUTER_MODEL=flux-schnell # Default model for x-router
