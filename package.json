{
  "name": "backend",
  "version": "0.0.1",
  "description": "The api for yallery",
  "author": "Mark Solomchak",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "build": "node --max-old-space-size=4096 ./node_modules/.bin/nest build && cp -r public dist/",
    "build:prod": "node --max-old-space-size=4096 ./node_modules/.bin/nest build && cp -r public dist/",
    "build:fallback": "npx tsc && cp -r public dist/",
    "build:direct": "npx tsc && cp -r public dist/",
    "start": "TS_NODE_BASEURL=./dist node -r tsconfig-paths/register dist/src/main.js",
    "start:dev": "TS_NODE_BASEURL=./dist NODE_OPTIONS='-r tsconfig-paths/register' nest start --watch",
    "start:debug": "TS_NODE_BASEURL=./dist NODE_OPTIONS='-r tsconfig-paths/register' nest start --debug --watch",
    "start:prod": "npm run build:direct && TS_NODE_BASEURL=./dist node -r tsconfig-paths/register dist/src/main.js",
    "start:prod:fallback": "npm run build:direct && TS_NODE_BASEURL=./dist node -r tsconfig-paths/register dist/src/main.js",
    "migration:show": "node --require ts-node/register --require tsconfig-paths/register ./node_modules/typeorm/cli.js migration:show -d ./src/core/database/data-source.ts",
    "migration:run": "node --require ts-node/register --require tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d ./src/core/database/data-source.ts",
    "migration:generate": "node --require ts-node/register --require tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d ./src/core/database/data-source.ts",
    "migration:create": "node --require ts-node/register ./node_modules/typeorm/cli.js migration:create",
    "provider-settings:seed-from-env": "node --require ts-node/register --require tsconfig-paths/register scripts/seed-provider-settings-from-env.ts",
    "migration:revert": "node --require ts-node/register --require tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d ./src/core/database/data-source.ts"
  },
  "dependencies": {
    "@arendajaelu/nestjs-passport-apple": "^2.0.2",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@bull-board/api": "^5.21.7",
    "@bull-board/express": "^5.21.7",
    "@bull-board/nestjs": "^5.21.7",
    "@bull-board/ui": "^5.21.7",
    "@google-cloud/local-auth": "^3.0.1",
    "@nestjs/bullmq": "^10.2.1",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.8",
    "@nestjs/platform-socket.io": "^10.3.10",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/throttler": "^6.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.3.10",
    "@octoai/sdk": "^1.4.0",
    "@sendgrid/mail": "^8.1.3",
    "@sentry/nestjs": "^8.47.0",
    "@sentry/profiling-node": "^9.1.0",
    "@types/multer": "^1.4.11",
    "adm-zip": "^0.5.16",
    "apple-signin-auth": "^1.7.6",
    "bad-words": "^4.0.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.3",
    "bullmq": "^5.13.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "connect-redis": "^8.0.2",
    "csv-writer": "^1.6.0",
    "date-fns": "^3.6.0",
    "express-session": "^1.18.1",
    "firebase-admin": "^12.3.0",
    "google-auth-library": "^9.11.0",
    "google-translate-api": "^2.3.0",
    "googleapis": "^140.0.1",
    "jszip": "^3.10.1",
    "leo-profanity": "^1.7.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.10.1",
    "openai": "^4.52.4",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-twitter": "^1.0.4",
    "redis": "^4.6.15",
    "reflect-metadata": "^0.2.0",
    "replicate": "^0.34.1",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "socket.io": "^4.7.5",
    "streamifier": "^0.1.1",
    "stripe": "^16.12.0",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0",
    "viem": "^2.39.2",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "workerpool": "^9.2.0",
    "x402-fetch": "^0.7.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.0.0",
    "@types/compression": "^1.8.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.3.1",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.7.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
