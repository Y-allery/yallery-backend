# ===========================================
# Yallery Backend Environment
# ===========================================
# Copy this file to .env and fill in real values.
# Do not commit real secrets.

# App
NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
HOME_URL=http://localhost:3000
WEB_APP_URL=http://localhost:3000

# Database
DATABASE_HOST=your_database_host
DATABASE_PORT=3306
DATABASE_USER=your_database_user
DATABASE_PASSWORD=your_database_password
DATABASE_NAME=your_database_name

# Redis
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Auth
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d
SETTINGS_ENCRYPTION_KEY=generate_with_openssl_rand_base64_32
# Shared secret between the Sentry hook and POST /ops-bot/internal-notify — generate with openssl rand -hex 32
OPS_INTERNAL_NOTIFY_SECRET=generate_with_openssl_rand_hex_32
SESSION_SECRET=your_session_secret

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
APPLE_CLIENT_ID=app.yallery
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_apple_private_key_here\n-----END PRIVATE KEY-----"
TWITTER_CONSUMER_KEY=your_twitter_consumer_key
TWITTER_CONSUMER_SECRET=your_twitter_consumer_secret
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# External APIs
OPENAI_API_KEY=your_openai_api_key
TWITTERAPI_IO_API_KEY=your_twitterapi_io_api_key
TWITTERAPI_IO_API_URL=https://api.twitterapi.io
TWITTERAPI_IO_RETWEETER_MAX_PAGES=10
TWITTERAPI_IO_PAGE_SIZE=200
TWITTER_ACCOUNT_NAME=y_allery
BRANCH_KEY=your_branch_key


# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_firebase_private_key_here\n-----END PRIVATE KEY-----\n"

# Email
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=your_sendgrid_from_email

# Rewards
SHARE_YEPS=5

# RunPod
RUNPOD_API_KEY=your_runpod_api_key
RUNPOD_API_BASE_URL=https://api.runpod.ai/v2
RUNPOD_POLL_INTERVAL_MS=5000
RUNPOD_REQUEST_TIMEOUT_MS=30000
RUNPOD_SYNC_REQUEST_TIMEOUT_MS=1800000
RUNPOD_COMPLETED_OUTPUT_RETRY_COUNT=5
RUNPOD_COMPLETED_OUTPUT_RETRY_DELAY_MS=2000
RUNPOD_FLUX2_KLEIN_ENDPOINT_ID=flux2-klein-endpoint
RUNPOD_FLUX2_KLEIN_ENABLED=true
RUNPOD_FLUX2_KLEIN_STATUS_TIMEOUT_MS=1200000
RUNPOD_SDXL_ENDPOINT_ID=sdxl-endpoint
RUNPOD_SDXL_ENABLED=true
RUNPOD_SDXL_STATUS_TIMEOUT_MS=1200000
RUNPOD_SDXL_LORA_FINETUNE_ENDPOINT_ID=sdxl-lora-finetune-endpoint
RUNPOD_SDXL_LORA_GENERATION_ENDPOINT_ID=sdxl-lora-generation-endpoint
RUNPOD_SDXL_LORA_GENERATION_ENABLED=true
RUNPOD_SDXL_LORA_GENERATION_STATUS_TIMEOUT_MS=1800000
RUNPOD_QWEN_IMAGE_EDIT_BAKED_ENDPOINT_ID=qwen-image-edit-endpoint
RUNPOD_QWEN_IMAGE_EDIT_BAKED_ENABLED=true
RUNPOD_MMAUDIO_ENDPOINT_ID=mmaudio-endpoint
RUNPOD_MMAUDIO_ENABLED=true
RUNPOD_MMAUDIO_STATUS_TIMEOUT_MS=7200000
RUNPOD_P_VIDEO_ENDPOINT_ID=p-video-endpoint
RUNPOD_P_VIDEO_ENABLED=true
RUNPOD_P_VIDEO_TEXT_STATUS_TIMEOUT_MS=7200000
RUNPOD_P_VIDEO_IMAGE_STATUS_TIMEOUT_MS=7200000
RUNPOD_WAN22_ANIMATE_MEME_ENDPOINT_ID=wan22-animate-meme-endpoint
RUNPOD_WAN22_ANIMATE_MEME_ENABLED=true
RUNPOD_WAN22_ANIMATE_MEME_STATUS_TIMEOUT_MS=7200000

# SPACES_REGION=fra1
# SPACES_BUCKET=yallery-media
# SPACES_ACCESS_KEY=your_spaces_access_key
# SPACES_SECRET_KEY=your_spaces_secret_key
# SPACES_CDN_BASE_URL=https://yallery-media.fra1.cdn.digitaloceanspaces.com
# Public base of this API for Cloudinary-compatible media URLs
# (/media/{image|video}/upload/<key>); unset -> raw CDN URLs are stored.
# MEDIA_PROXY_PUBLIC_BASE_URL=https://api.example.com
