# ===========================================
# ENVIRONMENT VARIABLES TEMPLATE
# ===========================================
# Copy this file to .env and fill in your actual values
# DO NOT commit actual values to git!

# ===========================================
# CRITICAL - MUST BE SET
# ===========================================

# Database Configuration
DB_HOST=your_database_host
DB_PORT=3306
DB_USERNAME=your_database_username
DB_PASSWORD=your_database_password
DB_DATABASE=your_database_name

# Redis Configuration
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT Configuration
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# Session Configuration (CRITICAL - CHANGE THIS!)
SESSION_SECRET=your_session_secret

# External APIs (CRITICAL - MUST BE SET)
TWEETSCOUT_API_KEY=your_tweetscout_api_key
TWEETSCOUT_API_URL=https://api.tweetscout.io/v2
TWITTER_SCORE_API_KEY=your_twitter_score_api_key
TWITTER_SCORE_API_URL=https://twitterscore.io/api/v1
TWITTER_ACCOUNT_ID=your_twitter_account_id
TWITTER_ACCOUNT_NAME=y_allery

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Optional: unsigned preset for direct video upload from browser
# CLOUDINARY_VIDEO_UPLOAD_PRESET=your_preset_name
# Optional: folder for those uploads (e.g. meme_reference_videos)
# CLOUDINARY_VIDEO_FOLDER=meme_reference_videos

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_firebase_private_key_here\n-----END PRIVATE KEY-----\n"

# SendGrid Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=your_sendgrid_from_email

# ===========================================
# APP CONFIGURATION
# ===========================================

NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000

# ===========================================
# EXISTING VARIABLES (KEEP THESE)
# ===========================================

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Apple OAuth
APPLE_CLIENT_ID=app.yallery
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_apple_private_key_here\n-----END PRIVATE KEY-----"

# Twitter OAuth
TWITTER_CONSUMER_KEY=your_twitter_consumer_key
TWITTER_CONSUMER_SECRET=your_twitter_consumer_secret
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Stripe
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# FAL (AI Service)
FAL_KEY=your_fal_key

# RunPod (Media Generation)
RUNPOD_API_KEY=your_runpod_api_key
RUNPOD_API_BASE_URL=https://api.runpod.ai/v2
RUNPOD_NANO_BANANA_ENDPOINT_ID=google-nano-banana-2-edit
RUNPOD_FLUX_SCHNELL_ENDPOINT_ID=black-forest-labs-flux-1-schnell
RUNPOD_QWEN_IMAGE_EDIT_ENDPOINT_ID=qwen-image-edit-2511
RUNPOD_P_VIDEO_ENDPOINT_ID=p-video

# Branch (Analytics)
BRANCH_KEY=your_branch_key

# Gmail
GMAIL_USERNAME=your_gmail_username
GMAIL_PASSWORD=your_gmail_password

# Encryption
ENCRYPTION_KEY=your_encryption_key
ENCRYPTION_IV=your_encryption_iv

# YEPS Configuration
LIKE_SPEND_YEPS=2
LIKE_EARN_YEPS=1
SHARING_REWARD_YEPS=5
IMAGE_GENERATE_SPEND_YEPS=5
YEPS_PER_REGISTRATION=500
DAILY_REWARD_YEPS=100
SHARE_YEPS=5
